  "failure_log": [
    {
      "week": "Feb 24 – Feb 28, 2026",
      "what_broke": "Personal OS frontend and backend were out of sync — hardcoded HTML was ignoring the JSON data source entirely.",
      "what_confused": "Why fetch() was returning 200 but the DOM wasn't updating. Turned out renderAll() wasn't being called after load.",
      "wrong_assumption": "Assumed the backend initialized content.json at startup. It didn't on second run.",
      "design_mistake": "Mixing hardcoded HTML with dynamic rendering led to duplication bugs.",
      "lesson": "Single source of truth must be enforced at architecture level, not patched."
    },
    {
      "week": "Feb 17 – Feb 23, 2026",
      "what_broke": "Mini shell crashed on SIGCHLD when zombie processes weren't reaped.",
      "what_confused": "Thought waitpid() call ordering didn't matter. It does.",
      "wrong_assumption": "Unix signal handling is simple. It's not.",
      "design_mistake": "Signal handler was doing too much — allocating memory inside the handler.",
      "lesson": "Keep signal handlers minimal. Use volatile sig_atomic_t flags."
    }
  ],
